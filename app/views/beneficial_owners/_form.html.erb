<%# Use shallow route: POST to /clients/:id/beneficial_owners for new, PATCH to /beneficial_owners/:id for existing %>
<%= form_with model: beneficial_owner,
              url: beneficial_owner.persisted? ? beneficial_owner_path(beneficial_owner) : client_beneficial_owners_path(client),
              local: true,
              data: { controller: "beneficial-owner-form" } do |form| %>
  <%= render "application/error_messages", resource: beneficial_owner %>

  <div class="space-y-6">
    <%# Basic Information %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div class="form-group">
        <%= form.label :name %>
        <%= form.text_field :name, required: true, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= form.label :ownership_percentage, "Ownership %" %>
        <%= form.number_field :ownership_percentage,
            min: 0,
            max: 100,
            step: 0.1,
            class: "form-control",
            placeholder: "e.g., 25.0" %>
      </div>
    </div>

    <div class="form-group">
      <%= form.label :control_type, "Control type" %>
      <%= form.select :control_type,
          options_for_select([
            ["Direct", "DIRECT"],
            ["Indirect", "INDIRECT"],
            ["Representative", "REPRESENTATIVE"]
          ], beneficial_owner.control_type),
          { include_blank: "Select control type..." } %>
    </div>

    <div class="form-group">
      <%= form.label :incorporation_country, "Incorporation country" %>
      <%= form.select :incorporation_country,
          options_for_select(country_options, beneficial_owner.incorporation_country),
          { include_blank: "Select country..." } %>
      <p class="form-hint">Applies to corporate beneficial owners only.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div class="form-group">
        <%= form.label :nationality %>
        <%= form.select :nationality,
            options_for_select(country_options, beneficial_owner.nationality),
            { include_blank: "Select country..." } %>
      </div>

      <div class="form-group">
        <%= form.label :residence_country, "Residence country" %>
        <%= form.select :residence_country,
            options_for_select(country_options, beneficial_owner.residence_country),
            { include_blank: "Select country..." } %>
      </div>
    </div>

    <div class="form-group">
      <%= form.label :net_worth_eur, "Net worth (EUR)" %>
      <%= form.number_field :net_worth_eur,
          min: 0,
          step: 1,
          class: "form-control",
          placeholder: "e.g., 10000000" %>
      <p class="form-hint">HNWI: >5M EUR | UHNWI: >50M EUR</p>
    </div>

    <%# Verification Section %>
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="form-picker-group">
          <%= form.check_box :identification_verified %>
          <div>
            <%= form.label :identification_verified, "Identity verified" %>
            <p class="form-hint">Identity documents have been checked and verified.</p>
          </div>
        </div>

        <div class="form-picker-group">
          <%= form.check_box :source_of_wealth_verified %>
          <div>
            <%= form.label :source_of_wealth_verified, "Source of wealth verified" %>
            <p class="form-hint">Source of wealth has been documented and verified.</p>
          </div>
        </div>
      </div>
    </div>

    <%# PEP Section %>
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <div class="form-picker-group">
        <%= form.check_box :is_pep,
            data: { beneficial_owner_form_target: "isPep", action: "change->beneficial-owner-form#togglePepType" } %>
        <div>
          <%= form.label :is_pep, "Politically Exposed Person" %>
          <p class="form-hint">This beneficial owner is a PEP or related to a PEP.</p>
        </div>
      </div>

      <div class="form-group mt-4 ml-7 <%= 'hidden' unless beneficial_owner.is_pep? %>" data-beneficial-owner-form-target="pepType">
        <%= form.label :pep_type, "PEP type" %>
        <%= form.select :pep_type,
            options_for_select([
              ["Domestic PEP", "DOMESTIC"],
              ["Foreign PEP", "FOREIGN"],
              ["International Organization", "INTL_ORG"]
            ], beneficial_owner.pep_type),
            { include_blank: "Select PEP type..." } %>
      </div>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-end gap-x-6">
    <% if beneficial_owner.persisted? %>
      <%= link_to "Cancel",
          client_path(client),
          class: "btn btn-secondary",
          data: { turbo_frame: dom_id(beneficial_owner) } %>
    <% else %>
      <%= link_to "Cancel",
          client_path(client),
          class: "btn btn-secondary",
          data: { turbo_frame: "new_beneficial_owner" } %>
    <% end %>
    <%= form.submit beneficial_owner.persisted? ? "Update" : "Add", class: "btn btn-primary" %>
  </div>
<% end %>
