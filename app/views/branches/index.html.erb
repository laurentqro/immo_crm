<% Current.meta_tags.set(title: "Branches & Subsidiaries") %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold leading-6 text-gray-900 dark:text-white">Branches, Subsidiaries & Agencies</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        Your entity's branches, subsidiaries, and agencies. Used for AMSF survey fields Q190-Q195.
      </p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to "Back to Settings", settings_path, class: "text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400" %>
    </div>
  </div>

  <%# Add form %>
  <div class="mt-8 bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
    <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-3">Add Branch</h3>
    <%= form_with model: @branch, url: branches_path, class: "flex items-end gap-4" do |f| %>
      <div class="flex-1">
        <%= f.label :name, "Branch Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.text_field :name, class: "mt-1 form-control", placeholder: "e.g. Paris Office", required: true %>
      </div>
      <div class="w-48">
        <%= f.label :country, "Country (ISO)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.text_field :country, class: "mt-1 form-control", placeholder: "e.g. FR", maxlength: 2, required: true, style: "text-transform: uppercase" %>
      </div>
      <div>
        <%= f.submit "Add", class: "btn btn-primary" %>
      </div>
    <% end %>
    <% if @branch.errors.any? %>
      <div class="mt-2 text-sm text-red-600 dark:text-red-400">
        <%= @branch.errors.full_messages.to_sentence %>
      </div>
    <% end %>
  </div>

  <%# List %>
  <div class="mt-6">
    <% if @branches.any? %>
      <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
        <thead>
          <tr>
            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Name</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Country</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Location</th>
            <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-0">
              <span class="sr-only">Actions</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @branches.each do |branch| %>
            <tr>
              <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 dark:text-white sm:pl-0"><%= branch.name %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= branch.country %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">
                <% if branch.country == "MC" %>
                  <span class="text-gray-400">Domestic</span>
                <% else %>
                  <span class="text-amber-600 dark:text-amber-400">Foreign</span>
                <% end %>
              </td>
              <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-0">
                <%= button_to "Remove", branch_path(branch), method: :delete,
                    class: "text-red-600 hover:text-red-900 dark:text-red-400",
                    data: { turbo_confirm: "Remove #{branch.name}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400 py-8 text-center">No branches added yet.</p>
    <% end %>
  </div>
</div>
