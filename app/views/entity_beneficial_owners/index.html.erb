<% Current.meta_tags.set(title: "Entity Beneficial Owners") %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold leading-6 text-gray-900 dark:text-white">Entity Beneficial Owners</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        Persons who own 25%+ or exercise control over your entity. Used for AMSF survey field Q197.
      </p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to "Back to Settings", settings_path, class: "text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400" %>
    </div>
  </div>

  <%# Add form %>
  <div class="mt-8 bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
    <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-3">Add Beneficial Owner</h3>
    <%= form_with model: @entity_beneficial_owner, url: entity_beneficial_owners_path, class: "flex items-end gap-4" do |f| %>
      <div class="flex-1">
        <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.text_field :name, class: "mt-1 form-control", placeholder: "e.g. Jean Dupont", required: true %>
      </div>
      <div class="w-64">
        <%= f.label :nationality, "Nationality", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.select :nationality,
            options_for_select(country_options, @entity_beneficial_owner.nationality),
            { include_blank: "Select country..." },
            { class: "mt-1 form-control", required: true } %>
      </div>
      <div>
        <%= f.submit "Add", class: "btn btn-primary" %>
      </div>
    <% end %>
    <% if @entity_beneficial_owner.errors.any? %>
      <div class="mt-2 text-sm text-red-600 dark:text-red-400">
        <%= @entity_beneficial_owner.errors.full_messages.to_sentence %>
      </div>
    <% end %>
  </div>

  <%# List %>
  <div class="mt-6">
    <% if @entity_beneficial_owners.any? %>
      <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
        <thead>
          <tr>
            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Name</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Nationality</th>
            <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-0">
              <span class="sr-only">Actions</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @entity_beneficial_owners.each do |bo| %>
            <tr>
              <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 dark:text-white sm:pl-0"><%= bo.name %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= ISO3166::Country[bo.nationality]&.iso_short_name || bo.nationality %></td>
              <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-0">
                <%= button_to "Remove", entity_beneficial_owner_path(bo), method: :delete,
                    class: "text-red-600 hover:text-red-900 dark:text-red-400",
                    data: { turbo_confirm: "Remove #{bo.name}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400 py-8 text-center">No beneficial owners added yet.</p>
    <% end %>
  </div>
</div>
