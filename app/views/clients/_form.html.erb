<%= form_with model: client, local: true, data: { controller: "client-form" } do |form| %>
  <%= render "application/error_messages", resource: client %>

  <div class="space-y-6">
    <%# Basic Information %>
    <div class="form-group">
      <%= form.label :name %>
      <%= form.text_field :name, required: true, class: "form-control" %>
    </div>

    <%# Client Type as Radio Buttons %>
    <fieldset class="form-group">
      <legend class="form-label">Client type <span class="text-red-500">*</span></legend>
      <div class="flex gap-6 mt-2">
        <% [["Natural Person", "NATURAL_PERSON"], ["Legal Entity", "LEGAL_ENTITY"]].each do |label, value| %>
          <label class="flex items-center gap-2 cursor-pointer">
            <%= form.radio_button :client_type, value,
                data: { client_form_target: "clientType", action: "change->client-form#toggleFields" },
                class: "form-radio" %>
            <span><%= label %></span>
          </label>
        <% end %>
      </div>
    </fieldset>

    <%# Legal Entity Type (only for Legal Entity) %>
    <div class="form-group <%= 'hidden' unless client.legal_entity? %>" data-client-form-target="legalEntityType">
      <%= form.label :legal_entity_type, "Legal form" %>
      <%= form.select :legal_entity_type,
          options_for_select(AmsfConstants::LEGAL_ENTITY_TYPE_LABELS.map { |k, v| [v, k] }, client.legal_entity_type),
          { include_blank: "Select legal form..." },
          { data: { action: "change->client-form#toggleLegalEntityType" } } %>
    </div>

    <%# Legal Entity Type Other (only when legal_entity_type == "OTHER") %>
    <div class="form-group ml-7 <%= 'hidden' unless client.legal_entity? && client.legal_entity_type == 'OTHER' %>" data-client-form-target="legalEntityTypeOther">
      <%= form.label :legal_entity_type_other, "Describe other legal form" %>
      <%= form.text_field :legal_entity_type_other,
          class: "form-control",
          placeholder: "e.g., Fiducie, groupement forestier..." %>
      <p class="form-hint">Required when legal form is "Other Legal Arrangements".</p>
    </div>

    <%# Trustees Section (only for Trust legal entities) %>
    <div class="<%= 'hidden' unless client.trust? %>" data-client-form-target="trusteeSection">
      <div class="border rounded-lg p-4 mb-2" style="border-color: var(--base-border-tertiary); background-color: var(--base-bg-secondary)">
        <h3 class="text-sm font-medium mb-4">Trustees</h3>

        <div data-client-form-target="trusteesContainer">
          <% client.trustees.each_with_index do |trustee, index| %>
            <%= form.fields_for :trustees, trustee do |tf| %>
              <%= render "clients/trustee_fields", form: tf, index: index %>
            <% end %>
          <% end %>
        </div>

        <button type="button" class="btn btn-secondary btn-sm mt-3" data-action="client-form#addTrustee">
          + Add trustee
        </button>
      </div>
    </div>

    <%# Country of Incorporation (for Legal Entity) %>
    <div class="form-group <%= 'hidden' unless client.legal_entity? %>" data-client-form-target="incorporationCountry">
      <%= form.label :incorporation_country, client.trust? ? "Country of creation" : "Country of incorporation" %>
      <%= form.select :incorporation_country,
          options_for_select(country_options, client.incorporation_country),
          { include_blank: "Select country..." },
          { class: "form-control", data: { client_form_target: "countryOptions" } } %>
      <p class="form-hint">Country where the entity is legally registered or has its head office (pays du siège ou de l'immatriculation).</p>
    </div>

    <%# Nationality and Residence (only for Natural Person and Trust, not Legal Entity) %>
    <div class="<%= 'hidden' if client.legal_entity? %>" data-client-form-target="naturalPersonFields">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div class="form-group">
          <%= form.label :nationality, "Primary nationality" %>
          <%= form.select :nationality,
              options_for_select(country_options, client.nationality),
              { include_blank: "Select country..." } %>
        </div>

        <div class="form-group">
          <%= form.label :residence_country, "Residence country" %>
          <%= form.select :residence_country,
              options_for_select(country_options, client.residence_country),
              { include_blank: "Select country..." } %>
        </div>
      </div>

      <%# Additional Nationalities %>
      <div class="mt-4">
        <div class="border rounded-lg p-4" style="border-color: var(--base-border-tertiary); background-color: var(--base-bg-secondary)">
          <h3 class="text-sm font-medium mb-3">Additional nationalities</h3>
          <p class="form-hint mb-3">Record all nationalities for dual or multi-national clients.</p>

          <div data-client-form-target="nationalitiesContainer">
            <% client.client_nationalities.each_with_index do |cn, index| %>
              <%= form.fields_for :client_nationalities, cn do |nf| %>
                <div class="nationality-entry flex items-end gap-3 mb-2" data-client-form-target="nationalityEntry">
                  <div class="form-group flex-1 mb-0">
                    <%= nf.select :country_code,
                        options_for_select(country_options, nf.object.country_code),
                        { include_blank: "Select country..." },
                        { class: "form-control" } %>
                  </div>
                  <% if nf.object.persisted? %>
                    <%= nf.hidden_field :id %>
                    <%= nf.hidden_field :_destroy, value: "0" %>
                  <% end %>
                  <button type="button" class="btn btn-sm text-red-600 mb-0" data-action="client-form#removeNationality">Remove</button>
                </div>
              <% end %>
            <% end %>
          </div>

          <button type="button" class="btn btn-secondary btn-sm mt-2" data-action="client-form#addNationality">
            + Add nationality
          </button>
        </div>
      </div>
    </div>

    <%# PEP Section %>
    <div class="border-t pt-6" style="border-color: var(--base-border-tertiary);">
      <div class="form-picker-group">
        <%= form.check_box :is_pep,
            data: { client_form_target: "isPep", action: "change->client-form#togglePepType" } %>
        <div>
          <%= form.label :is_pep, "Politically Exposed Person" %>
          <p class="form-hint">Client is a PEP or related to a PEP.</p>
        </div>
      </div>

      <div class="form-group mt-4 ml-7 <%= 'hidden' unless client.is_pep? %>" data-client-form-target="pepType">
        <%= form.label :pep_type, "PEP type" %>
        <%= form.select :pep_type,
            options_for_select([
              ["Domestic PEP", "DOMESTIC"],
              ["Foreign PEP", "FOREIGN"],
              ["International Organization", "INTL_ORG"]
            ], client.pep_type),
            { include_blank: "Select PEP type..." } %>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 mt-4">
        <div class="form-picker-group">
          <%= form.check_box :is_pep_related %>
          <div>
            <%= form.label :is_pep_related, "Related to a PEP" %>
            <p class="form-hint">Client is a family member of a PEP.</p>
          </div>
        </div>

        <div class="form-picker-group">
          <%= form.check_box :is_pep_associated %>
          <div>
            <%= form.label :is_pep_associated, "Associated with a PEP" %>
            <p class="form-hint">Client has a close business relationship with a PEP.</p>
          </div>
        </div>
      </div>
    </div>

    <%# VASP Section %>
    <div class="border-t pt-6" style="border-color: var(--base-border-tertiary);">
      <div class="form-picker-group">
        <%= form.check_box :is_vasp,
            data: { client_form_target: "isVasp", action: "change->client-form#toggleVaspType" } %>
        <div>
          <%= form.label :is_vasp, "Virtual Asset Service Provider (VASP)" %>
          <p class="form-hint">Client is a PSAV/VASP (prestataire de services sur actifs virtuels).</p>
        </div>
      </div>

      <div class="form-group mt-4 ml-7 <%= 'hidden' unless client.is_vasp? %>" data-client-form-target="vaspType">
        <%= form.label :vasp_type, "VASP type" %>
        <%= form.select :vasp_type,
            options_for_select(AmsfConstants::VASP_TYPE_LABELS.map { |k, v| [v, k] }, client.vasp_type),
            { include_blank: "Select VASP type..." },
            { data: { action: "change->client-form#toggleVaspType" } } %>
        <p class="form-hint">Type of virtual asset service provided by this client.</p>
      </div>

      <div class="form-group mt-4 ml-7 <%= 'hidden' unless client.is_vasp? && client.vasp_type == 'OTHER' %>" data-client-form-target="vaspOtherServiceType">
        <%= form.label :vasp_other_service_type, "Describe other VASP service" %>
        <%= form.text_field :vasp_other_service_type,
            class: "form-control",
            placeholder: "e.g., Crypto ATM operator, P2P trading platform..." %>
        <p class="form-hint">Required when VASP type is "Other".</p>
      </div>
    </div>

    <%# Risk Level %>
    <div class="form-group">
      <%= form.label :risk_level, "Risk level" %>
      <%= form.select :risk_level,
          options_for_select([
            ["Low", "LOW"],
            ["Medium", "MEDIUM"],
            ["High", "HIGH"]
          ], client.risk_level),
          { include_blank: "Select risk level..." } %>
    </div>

    <%# Net Worth Range (Natural Persons only) %>
    <div class="form-group <%= 'hidden' unless client.natural_person? %>" data-client-form-target="netWorthRange">
      <%= form.label :net_worth_range, "Net worth range" %>
      <%= form.select :net_worth_range,
          options_for_select([
            ["Under EUR 5M", "UNDER_5M"],
            ["EUR 5M – 50M (HNWI)", "5M_TO_50M"],
            ["Over EUR 50M (UHNWI)", "OVER_50M"]
          ], client.net_worth_range),
          { include_blank: "Select range..." } %>
      <p class="form-hint">AMSF thresholds: HNWI > EUR 5M, UHNWI > EUR 50M.</p>
    </div>

    <%# Due Diligence Section %>
    <div class="border-t pt-6" style="border-color: var(--base-border-tertiary);">
      <h3 class="text-sm font-medium mb-4" style="color: var(--base-text-secondary);">Due Diligence</h3>

      <div class="form-group">
        <%= form.label :due_diligence_level, "Due diligence level" %>
        <%= form.select :due_diligence_level,
            options_for_select([
              ["Standard", "STANDARD"],
              ["Simplified", "SIMPLIFIED"],
              ["Reinforced (Enhanced)", "REINFORCED"]
            ], client.due_diligence_level),
            { include_blank: "Select level..." },
            {
              data: {
                client_form_target: "dueDiligenceLevel",
                action: "change->client-form#toggleSimplifiedReason"
              }
            } %>
        <p class="form-hint">AMSF requirement: Standard for most clients, Simplified for low-risk regulated entities, Reinforced for high-risk or PEPs.</p>
      </div>

      <div class="form-group <%= 'hidden' unless client.due_diligence_level == 'SIMPLIFIED' %>" data-client-form-target="simplifiedDdReason">
        <%= form.label :simplified_dd_reason, "Simplified DD justification" %>
        <%= form.text_area :simplified_dd_reason,
            rows: 2,
            class: "form-control",
            placeholder: "Explain why simplified due diligence applies (e.g., regulated entity, low-risk profile)..." %>
        <p class="form-hint">Required when using simplified due diligence.</p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 mt-4">
        <div class="form-picker-group">
          <%= form.check_box :source_of_funds_verified %>
          <div>
            <%= form.label :source_of_funds_verified, "Source of funds verified" %>
            <p class="form-hint">Origin of funds for transactions has been documented.</p>
          </div>
        </div>

        <div class="form-picker-group">
          <%= form.check_box :source_of_wealth_verified %>
          <div>
            <%= form.label :source_of_wealth_verified, "Source of wealth verified" %>
            <p class="form-hint">Overall wealth origin has been documented.</p>
          </div>
        </div>
      </div>
    </div>

    <%# Professional Category %>
    <div class="form-group">
      <%= form.label :professional_category, "Professional category" %>
      <%= form.select :professional_category,
          options_for_select([
            ["Legal professional", "LEGAL"],
            ["Accountant", "ACCOUNTANT"],
            ["Notary", "NOTARY"],
            ["Real estate professional", "REAL_ESTATE"],
            ["Financial professional", "FINANCIAL"],
            ["Other regulated professional", "OTHER"],
            ["None / Not applicable", "NONE"]
          ], client.professional_category),
          { include_blank: "Select category..." } %>
      <p class="form-hint">If the client is a regulated professional subject to their own AML/CFT obligations.</p>
    </div>

    <%# Relationship End Section %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div class="form-group">
        <%= form.label :relationship_end_reason, "Relationship end reason" %>
        <%= form.select :relationship_end_reason,
            options_for_select([
              ["Client request", "CLIENT_REQUEST"],
              ["AML/CFT concern", "AML_CONCERN"],
              ["Inactivity", "INACTIVITY"],
              ["Business decision", "BUSINESS_DECISION"],
              ["Other", "OTHER"]
            ], client.relationship_end_reason),
            { include_blank: "Still active client..." } %>
        <p class="form-hint">Reason for ending the business relationship (if applicable).</p>
      </div>

      <div class="form-group">
        <%= form.label :rejection_reason, "Rejection reason" %>
        <%= form.select :rejection_reason,
            options_for_select([
              ["AML/CFT concern", "AML_CFT"],
              ["Other", "OTHER"]
            ], client.rejection_reason),
            { include_blank: "Not rejected..." } %>
        <p class="form-hint">If the prospect was rejected during onboarding.</p>
      </div>
    </div>

    <%# Business Sector (AMSF high-risk sector classification, all client types) %>
    <div class="form-group">
      <%= form.label :business_sector, "Business sector" %>
      <%= form.select :business_sector,
          options_for_select(AmsfConstants::BUSINESS_SECTOR_LABELS.map { |k, v| [v, k] }, client.business_sector),
          { include_blank: "Select business sector..." },
          { class: "form-control" } %>
      <p class="form-hint">AMSF high-risk business sector classification (if applicable).</p>
    </div>

    <%# Business Introducer Section %>
    <div class="border-t pt-6" style="border-color: var(--base-border-tertiary);">
      <h3 class="text-sm font-medium mb-4" style="color: var(--base-text-secondary);">Business Introducer</h3>

      <div class="form-picker-group">
        <%= form.check_box :introduced_by_third_party,
            data: { client_form_target: "introducedByThirdParty", action: "change->client-form#toggleIntroducerCountry" } %>
        <div>
          <%= form.label :introduced_by_third_party, "Client was introduced by a third party" %>
          <p class="form-hint">Business relationship was initiated through an external introducer.</p>
        </div>
      </div>

      <div class="form-group mt-4 ml-7 <%= 'hidden' unless client.introduced_by_third_party? %>" data-client-form-target="introducerCountry">
        <%= form.label :introducer_country, "Introducer country" %>
        <%= form.select :introducer_country,
            options_for_select(country_options, client.introducer_country),
            { include_blank: "Select country..." },
            { class: "form-control" } %>
        <p class="form-hint">Country of residence of the introducing party.</p>
      </div>
    </div>

    <%# Third-Party CDD Section %>
    <div class="border-t pt-6" style="border-color: var(--base-border-tertiary);">
      <h3 class="text-sm font-medium mb-4" style="color: var(--base-text-secondary);">Third-Party Customer Due Diligence</h3>

      <div class="form-picker-group">
        <%= form.check_box :third_party_cdd,
            data: { client_form_target: "thirdPartyCdd", action: "change->client-form#toggleThirdPartyCdd" } %>
        <div>
          <%= form.label :third_party_cdd, "CDD performed by a third party" %>
          <p class="form-hint">Customer due diligence was conducted by an external party (e.g., another regulated entity).</p>
        </div>
      </div>

      <fieldset class="form-group mt-4 ml-7 <%= 'hidden' unless client.third_party_cdd? %>" data-client-form-target="thirdPartyCddType">
        <legend class="form-label">Third-party provider type</legend>
        <div class="flex gap-6 mt-2">
          <% [["Local (Monaco)", "LOCAL"], ["Foreign", "FOREIGN"]].each do |label, value| %>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= form.radio_button :third_party_cdd_type, value,
                  data: { action: "change->client-form#toggleThirdPartyCdd" },
                  class: "form-radio" %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
        <p class="form-hint mt-1">Whether the CDD provider is based in Monaco or abroad.</p>
      </fieldset>

      <div class="form-group mt-4 ml-7 <%= 'hidden' unless client.third_party_cdd? && client.third_party_cdd_type == 'FOREIGN' %>" data-client-form-target="thirdPartyCddCountry">
        <%= form.label :third_party_cdd_country, "Third-party provider country" %>
        <%= form.select :third_party_cdd_country,
            options_for_select(country_options, client.third_party_cdd_country),
            { include_blank: "Select country..." },
            { class: "form-control" } %>
        <p class="form-hint">Country of residence of the foreign CDD provider.</p>
      </div>
    </div>

    <%# Became Client Date %>
    <div class="form-group">
      <%= form.label :became_client_at, "Client since" %>
      <%= form.date_field :became_client_at, class: "form-control" %>
    </div>

    <%# Notes %>
    <div class="form-group">
      <%= form.label :notes %>
      <%= form.text_area :notes,
          rows: 3,
          class: "form-control",
          placeholder: "Additional notes about this client..." %>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-end gap-x-6">
    <%= link_to "Cancel", clients_path, class: "btn btn-secondary" %>
    <%= form.submit client.persisted? ? "Update Client" : "Create Client", class: "btn btn-primary" %>
  </div>
<% end %>
