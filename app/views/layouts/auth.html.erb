<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= render "head" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&display=swap" rel="stylesheet">
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --navy: #0f2b4a;
        --navy-mid: #1a3d66;
        --navy-light: #245280;
        --navy-wash: #f0f4f8;
        --accent: #3b82f6;
        --green: #059669;
        --red: #dc2626;
        --gray-100: #f5f5f5;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-800: #1f2937;
        --gray-900: #0a0f1a;
      }

      body {
        font-family: "DM Sans", system-ui, -apple-system, sans-serif;
        color: var(--gray-900);
        background: var(--navy-wash);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ---- Nav ---- */
      .auth-nav {
        padding: 0 2rem;
        border-bottom: 1px solid var(--gray-200);
        background: #fff;
      }

      .auth-nav-inner {
        max-width: 68rem;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 3.5rem;
      }

      .auth-nav-logo {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--navy);
        text-decoration: none;
        letter-spacing: -0.02em;
      }

      .auth-nav-logo span {
        font-family: Monaco, "Cascadia Mono", "SF Mono", Menlo, Consolas, monospace;
        font-weight: 400;
        color: var(--accent);
      }

      .auth-nav-link {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--gray-500);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        transition: color 0.2s;
      }

      .auth-nav-link:hover {
        color: var(--navy);
      }

      /* ---- Main ---- */
      .auth-main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
        position: relative;
      }

      .auth-main::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 50% at 50% 0%, rgba(15, 43, 74, 0.03) 0%, transparent 70%);
        pointer-events: none;
      }

      /* ---- Card ---- */
      .auth-card {
        position: relative;
        width: 100%;
        max-width: 24rem;
        background: #fff;
        border: 1px solid var(--gray-200);
        border-radius: 1rem;
        padding: 2.5rem 2rem 2rem;
        box-shadow: 0 1px 3px rgba(15, 43, 74, 0.04), 0 8px 32px rgba(15, 43, 74, 0.06);
      }

      .auth-header {
        text-align: center;
        margin-bottom: 2rem;
      }

      .auth-title {
        font-size: 1.375rem;
        font-weight: 700;
        color: var(--gray-900);
        letter-spacing: -0.02em;
        margin-bottom: 0.375rem;
      }

      .auth-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
        line-height: 1.5;
      }

      .auth-subtitle a {
        color: var(--navy);
        font-weight: 600;
        text-decoration: none;
        border-bottom: 1px solid var(--gray-200);
        padding-bottom: 1px;
        transition: border-color 0.2s;
      }

      .auth-subtitle a:hover {
        border-color: var(--navy);
      }

      /* ---- Form ---- */
      .auth-form .form-group {
        margin-bottom: 1.25rem;
      }

      .auth-form label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--gray-800);
        margin-bottom: 0.375rem;
        letter-spacing: 0.01em;
      }

      .auth-form .form-control {
        width: 100%;
        padding: 0.625rem 0.875rem;
        font-family: "DM Sans", system-ui, sans-serif;
        font-size: 0.9375rem;
        color: var(--gray-900);
        background: #fff;
        border: 1px solid var(--gray-300);
        border-radius: 0.5rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
      }

      .auth-form .form-control::placeholder {
        color: var(--gray-400);
      }

      .auth-form .form-control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
      }

      .auth-form .form-picker-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0;
      }

      .auth-form .form-picker-group input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        accent-color: var(--navy);
        border-radius: 0.25rem;
        cursor: pointer;
      }

      .auth-form .form-picker-group label {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--gray-600);
        margin-bottom: 0;
        cursor: pointer;
      }

      .auth-form .btn-primary {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--navy);
        color: #fff;
        padding: 0.6875rem 1.5rem;
        border-radius: 0.5rem;
        font-family: "DM Sans", system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.9375rem;
        letter-spacing: 0.01em;
        border: none;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        box-shadow: 0 1px 3px rgba(15, 43, 74, 0.15), 0 4px 12px rgba(15, 43, 74, 0.1);
      }

      .auth-form .btn-primary:hover {
        background: var(--navy-mid);
        box-shadow: 0 2px 6px rgba(15, 43, 74, 0.2), 0 8px 24px rgba(15, 43, 74, 0.15);
        transform: translateY(-1px);
      }

      .auth-form .btn-primary:active {
        transform: translateY(0);
      }

      /* ---- Divider ---- */
      .auth-divider {
        border: none;
        border-top: 1px solid var(--gray-200);
        margin: 1.5rem 0;
      }

      /* ---- Links ---- */
      .auth-links {
        margin-top: 1.25rem;
        text-align: center;
      }

      .auth-links a {
        display: inline-block;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--gray-500);
        text-decoration: none;
        transition: color 0.2s;
        margin-top: 0.25rem;
      }

      .auth-links a:hover {
        color: var(--navy);
      }

      /* ---- OAuth ---- */
      .auth-oauth {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        margin-bottom: 0;
      }

      .auth-oauth .btn {
        flex: 1;
        min-width: 0;
      }

      /* ---- Flash ---- */
      .auth-flash {
        width: 100%;
        max-width: 24rem;
        margin-bottom: 1rem;
      }

      .auth-flash .alert {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.8125rem;
        font-weight: 500;
      }

      /* ---- Footer ---- */
      .auth-footer {
        text-align: center;
        padding: 1.5rem 2rem;
        font-size: 0.75rem;
        color: var(--gray-400);
      }

      .auth-footer a {
        color: var(--gray-500);
        text-decoration: none;
        transition: color 0.2s;
      }

      .auth-footer a:hover {
        color: var(--navy);
      }

      /* ---- Responsive ---- */
      @media (max-width: 480px) {
        .auth-card {
          border-radius: 0.75rem;
          padding: 2rem 1.5rem 1.75rem;
        }
      }
    </style>
  </head>
  <body>
    <nav class="auth-nav">
      <div class="auth-nav-inner">
        <%= link_to root_path, class: "auth-nav-logo" do %>Business <span>OS</span><% end %>
        <% if controller_name == "sessions" %>
          <%= link_to new_registration_path(:user), class: "auth-nav-link" do %>Créer un compte <span>&rarr;</span><% end %>
        <% else %>
          <%= link_to new_session_path(:user), class: "auth-nav-link" do %>Se connecter <span>&rarr;</span><% end %>
        <% end %>
      </div>
    </nav>

    <main class="auth-main">
      <%= content_for?(:content) ? yield(:content) : yield %>
    </main>

    <footer class="auth-footer">
      <p>&copy; 2026 <a href="https://curau.me" target="_blank" rel="noopener">Laurent Curau</a> · Monaco</p>
    </footer>
  </body>
</html>
